rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Deny all access by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Exports are accessed only via signed URLs generated by Cloud Functions.
    match /exports/{eventId}/{fileName} {
      allow read, write: if false;
    }
  }
}

